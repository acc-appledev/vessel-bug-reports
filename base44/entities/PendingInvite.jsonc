{
  "name": "PendingInvite",
  "type": "object",
  "properties": {
    "email": {
      "type": "string",
      "description": "Email address to invite"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "sent",
        "failed"
      ],
      "default": "pending"
    },
    "error": {
      "type": "string",
      "description": "Error message if failed"
    }
  },
  "required": [
    "email"
  ]
}